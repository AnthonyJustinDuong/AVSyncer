# Copy to .env and fill in. Never commit .env.
OPENAI_API_KEY=

# Leave blank to use llm when OPENAI_API_KEY is set, otherwise deterministic.
# Set to deterministic to force the older heuristic detector.
TAKE_DETECTOR_MODE=
TAKE_DETECTOR_LLM_MODEL=gpt-5.4
TAKE_DETECTOR_LLM_REASONING_EFFORT=high

# Leave blank to use llm when OPENAI_API_KEY is set, otherwise deterministic.
# Set to deterministic to force local punctuation/gap-based caption cue splits.
CAPTION_SPLIT_MODE=
CAPTION_SPLIT_LLM_MODEL=gpt-5.4
CAPTION_SPLIT_LLM_REASONING_EFFORT=medium

# Optional: override the bundled Poppins export font with a local .ttf/.ttc file.
# If blank, export uses backend/assets/fonts/Poppins-ExtraBold.ttf.
CAPTION_FONT_PATH=
